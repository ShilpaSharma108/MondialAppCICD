<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Single Test Suite" verbose="1">

    <listeners>
        <listener class-name="com.mondial.listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>
    <parameter name="os" value="windows"/>
    <parameter name="headless" value="false"/>

    <test name="Verify Transaction History">
        <classes>
            <class name="com.mondial.tests.tempated.report.I_VerifyTransactionHistory"/>
        </classes>
    </test>

    <test name="Verify Balance Details Trial Balance">
        <classes>
            <class name="com.mondial.tests.tempated.report.II_VerifyBalanceDetails_TrialBalance"/>
        </classes>
    </test>

    <test name="Verify Balance Details Current Period TB">
        <classes>
            <class name="com.mondial.tests.tempated.report.III_VerifyBalanceDetails_CurrentPeriodTB"/>
        </classes>
    </test>

    <test name="Verify Balance Details Detailed Trial Balance">
        <classes>
            <class name="com.mondial.tests.tempated.report.IV_VerifyBalanceDetails_DetailedTrialBalance"/>
        </classes>
    </test>

    <test name="Verify Trial Balance For All Transaction Types">
        <classes>
            <class name="com.mondial.tests.tempated.report.V_VerifyTrialBalance_AllTxnTypes"/>
        </classes>
    </test>

    <test name="Verify Trial Balance With Accounting Period">
        <classes>
            <class name="com.mondial.tests.tempated.report.VII_VerifyTrialBalance_AccountingPeriod"/>
        </classes>
    </test>

    <test name="Verify Trial Balance For All Currencies">
        <classes>
            <class name="com.mondial.tests.tempated.report.VIII_VerifyTrialBalance_AllCurrencies"/>
        </classes>
    </test>

    <test name="Verify Trial Balance For All Natural Account Sets">
        <classes>
            <class name="com.mondial.tests.tempated.report.IX_VerifyTrialBalance_AllNaturalAccountSets"/>
        </classes>
    </test>

    <test name="Verify Trial Balance For All Ledgers">
        <classes>
            <class name="com.mondial.tests.tempated.report.X_VerifyTrialBalance_AllLedgers"/>
        </classes>
    </test>

    <test name="Verify All Report Types">
        <classes>
            <class name="com.mondial.tests.tempated.report.XI_VerifyAllReportTypes"/>
        </classes>
    </test>

    <test name="Verify Download">
        <classes>
            <class name="com.mondial.tests.tempated.report.XII_VerifyDownload"/>
        </classes>
    </test>

</suite>
