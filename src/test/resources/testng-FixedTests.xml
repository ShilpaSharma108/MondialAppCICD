<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Single Test Suite" verbose="1">

    <listeners>
        <listener class-name="com.mondial.listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>
    <parameter name="os" value="windows"/>
    <parameter name="headless" value="false"/>

    <test name="CR Vendors Grid">
        <classes>
            <class name="com.mondial.tests.company.CR_VendorsGridTest"/>
        </classes>
    </test>

    <test name="CR Accounting Period">
        <classes>
            <class name="com.mondial.tests.company.CR_AccountingPeriod"/>
        </classes>
    </test>

    <test name="CR Segment Options All">
        <classes>
            <class name="com.mondial.tests.company.CR_SegmentOptionsAllTest"/>
        </classes>
    </test>

    <test name="Integration Report Header In Report">
        <classes>
            <class name="com.mondial.tests.integrations.IntegrationReportHeaderInReport"/>
        </classes>
    </test>

</suite>
