<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Single Test Suite" verbose="1">

    <listeners>
        <listener class-name="com.mondial.listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>
    <parameter name="os" value="windows"/>
    <parameter name="headless" value="false"/>

    <test name="ES Exchange Rate Source CRUD">
        <classes>
            <class name="com.mondial.tests.enterprise.ES_ExchangeRateSource_CRUD"/>
        </classes>
    </test>

    <test name="ES Get Exchange Rates">
        <classes>
            <class name="com.mondial.tests.enterprise.ES_GetExchangeRates"/>
        </classes>
    </test>

    <test name="ES Sort Exchange Rates">
        <classes>
            <class name="com.mondial.tests.enterprise.ES_SortExchangeRates"/>
        </classes>
    </test>

    <test name="ES Exchange Verify CSV Upload Download">
        <classes>
            <class name="com.mondial.tests.enterprise.ES_ExchangeVerifyCSVUploadDownload"/>
        </classes>
    </test>

    <test name="ES Exchange Verify Unauthorised User Unable to Access">
        <classes>
            <class name="com.mondial.tests.enterprise.ES_Exchange_VerifyUnauthorisedUserUnabletoAccess"/>
        </classes>
    </test>

</suite>
