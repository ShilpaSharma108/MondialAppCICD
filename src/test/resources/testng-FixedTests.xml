<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Single Test Suite" verbose="1">

    <listeners>
        <listener class-name="com.mondial.listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>
    <parameter name="os" value="windows"/>
    <parameter name="headless" value="false"/>

    <test name="Reporting Currency Without Journal">
        <classes>
            <class name="com.mondial.tests.company.CR_ReportingCurrency_WithoutJournal"/>
        </classes>
    </test>

    <test name="Reporting Currency With Journal">
        <classes>
            <class name="com.mondial.tests.company.CR_ReportingCurrency_WithJournal"/>
        </classes>
    </test>

</suite>
