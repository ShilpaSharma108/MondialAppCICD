<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Single Test Suite" verbose="1">

    <listeners>
        <listener class-name="com.mondial.listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>
    <parameter name="os" value="windows"/>
    <parameter name="headless" value="false"/>

    <test name="ES Get Exchange Rates">
        <classes>
            <class name="com.mondial.tests.enterprise.ES_GetExchangeRates"/>
        </classes>
    </test>

    <test name="ES Users Error Messages">
        <classes>
            <class name="com.mondial.tests.enterprise.ES_Users_ErrorMessages"/>
        </classes>
    </test>

    <test name="V Verify Trial Balance All Txn Types">
        <classes>
            <class name="com.mondial.tests.templated.report.V_VerifyTrialBalance_AllTxnTypes"/>
        </classes>
    </test>

    <test name="CSV Download Upload Cross Page Tests">
        <classes>
            <class name="com.mondial.tests.csvdownloadupload.CSV_DownloadUploadCrossPageTest"/>
        </classes>
    </test>

</suite>
