<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Single Test Suite" verbose="1">

    <listeners>
        <listener class-name="com.mondial.listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>
    <parameter name="os" value="ubuntu"/>
    <parameter name="headless" value="true"/>

    <test name="Chart of Accounts CRUD Tests">
        <classes>
            <class name="com.mondial.tests.company.CR_COACrudTest"/>
        </classes>
    </test>

</suite>
