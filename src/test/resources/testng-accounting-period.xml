<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Accounting Period Suite" verbose="1">

    <parameter name="browser" value="chrome"/>
    <parameter name="os" value="windows"/>
    <parameter name="headless" value="false"/>

    <test name="Add Accounting Period Tests">
        <classes>
            <class name="com.mondial.tests.company.AddAccountingPeriod"/>
        </classes>
    </test>

    <test name="Lock Unlock Accounting Period Tests">
        <classes>
            <class name="com.mondial.tests.company.LockUnlockAccoutingPeriod"/>
        </classes>
    </test>

</suite>
